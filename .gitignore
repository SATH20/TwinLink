# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env
.env.local
.env.development
.env.test
.env.production
*.env
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Firebase credentials
private.json
serviceAccountKey.json
firebase-adminsdk*.json
*-firebase-adminsdk-*.json

# API Keys and Secrets
secrets/
*.key
*.p12
*.pfx
*.cer
*.crt
config/secrets.ts
config/secrets.js

# Backend specific
backend/private.json
backend/secrets/
backend/*.key

# FastAPI specific
fastapi-engine/.env
fastapi-engine/secrets/
fastapi-engine/*.key

# Database
*.db
*.sqlite
*.sqlite3

# Documentation (except README)
*.md
!README.md
